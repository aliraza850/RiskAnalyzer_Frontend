{"file":"_id_-Cr1BUcrB.js","mappings":";;;;;;;;;;;;;;;;;;;AAgOAA,UAAQ;AAAA,MACN;AAAA,MACA;AAAA,MACA;AAAA,MACA;AAAA,MACA;AAAA,MACA;AAAA,IAAA;AAGY,aAAA;AACC,cAAA;AACf,UAAM,SAAS,IAAI,IAAI;AACvB,UAAM,QAAQ,IAAI,IAAI;AA6BtB,UAAM,oBAAoB,CAAC,OAAO,OAAO,WAAW;AAChD,UAAI,SAAS,IAAI;AACb,eAAO,SAAS,SAAS,6BAA8B,SAAS,WAAW,kCAAkC;AAAA,MACjH;AACA,UAAI,SAAS,IAAI;AACb,eAAO,SAAS,SAAS,oBAAqB,SAAS,WAAW,yBAAyB;AAAA,MAC/F;AACA,aAAO,SAAS,SAAS,sBAAuB,SAAS,WAAW,2BAA2B;AAAA,IACnG;AAEA,UAAM,oBAAoB,CAAC,UAAU;AACjC,UAAI,SAAS,GAAI,QAAO;AACxB,UAAI,SAAS,GAAI,QAAO;AACxB,aAAO;AAAA,IACX;AAIA,UAAM,YAAY,SAAS,MAAM;AAC7B,UAAI,CAAC,OAAO,SAAS,CAAC,OAAO,MAAM,eAAgB,QAAO;AAC1D,YAAM,OAAO,OAAO,MAAM;AAC1B,aAAO;AAAA,QACH,QAAQ,CAAC,aAAa,eAAe,UAAU,SAAS,cAAc;AAAA,QACtE,UAAU,CAAC;AAAA,UACP,OAAO;AAAA,UACP,iBAAiB;AAAA,UACjB,aAAa;AAAA,UACb,sBAAsB;AAAA,UACtB,kBAAkB;AAAA,UAClB,2BAA2B;AAAA,UAC3B,uBAAuB;AAAA,UACvB,MAAM;AAAA,YACF,KAAK,aAAa;AAAA,YAClB,KAAK,eAAe;AAAA,YACpB,KAAK,UAAU;AAAA,YACf,KAAK,SAAS;AAAA,YACd,KAAK,gBAAgB;AAAA,UAAA;AAAA,QACzB,CACH;AAAA,MAAA;AAAA,IAET,CAAC;AAED,UAAM,eAAe;AAAA,MACjB,YAAY;AAAA,MACZ,qBAAqB;AAAA,MACrB,QAAQ;AAAA,QACJ,GAAG;AAAA,UACC,YAAY,EAAE,OAAO,2BAAA;AAAA,UACrB,MAAM,EAAE,OAAO,4BAAA;AAAA,UACf,aAAa;AAAA,YACX,OAAO;AAAA,YACP,MAAM;AAAA,cACJ,MAAM;AAAA,cACN,QAAQ;AAAA,cACR,QAAQ;AAAA,YAAA;AAAA,UACV;AAAA,UAEF,OAAO,EAAE,SAAS,OAAO,KAAK,GAAG,KAAK,IAAA;AAAA,QAAI;AAAA,MAC9C;AAAA,MAEJ,SAAS;AAAA,QACL,QAAQ,EAAE,SAAS,MAAA;AAAA,MAAM;AAAA,IAC7B;;;UAtU4B,OAAA,OAAM;AAA/B,cAAA,OAAAC,eAAAC,WAAA,EAAA,OAAM,gBAAY,MAAA,CAAA,CAAA,0HAAA;;UAET,IAAG;AAAA,UAAa,OAAM;AAAA,QAAA;2BAAhC,CAEW,GAAAC,QAAAC,UAAA,aAAA;;;;;gBADTC,YAAiE,QAAA,EAA3D,OAAM,oCAAA,GAAoC,YAAU;AAAA,gCAAO,qBACnE;AAAA,cAAA;AAAA;;;;ukDAoBWC,eAAA,OAAA,MAAO,KAAK,yqBAWsBA,eAAA,IAAA,KAAK,OAAA,MAAO,SAAS,EAAE,mBAAA,CAAkB,iVAKnCA,eAAA,OAAA,MAAO,UAAU,sVAK1B,OAAA,MAAO,IAAI,UAAS,GAAA,CAAA,CAAA,4yBAWtC,kBAAkB,OAAA,MAAO,cAAY,MAAA,GAAA,uCAAA,CAAA,0DAAmD,oBAAgB,IAAM,KAAK,KAAE,EAAA,IAAQC,cAAA,yBAAuB,KAAK,KAAE,MAAA,IAAa,OAAA,MAAO,eAAY,IAAA,yPAGrID,eAAA,OAAA,MAAO,YAAY,qJAI3B,kBAAkB,OAAA,MAAO,YAAY,GAAA,8CAAA,CAAA,qCAClG,kBAAkB,OAAA,MAAO,YAAY,CAAA;YAuB3B,UAAA,OAAS;;YAAG,MAAM,UAAA;AAAA,YAAY,SAAS;AAAA,UAAA;;;;4/BAwBUA,eAAA,OAAA,MAAO,eAAe,iVAGmFE,eAAA,EAAA,OAAA,OAAA,MAAO,kBAAe,IAAA,CAAA,sZAQ/IF,eAAA,OAAA,MAAO,eAAY,KAAA,uBAAA,eAAA,sUAInBA,eAAA,OAAA,MAAO,eAAY,KAAA,0BAAA,UAAA;AAQjCG,sBAAA,OAAA,MAAO,gBAAc,CAApC,OAAO,QAAG;wJAA+C,QAAK,KAAA,OAAA,EAAA,SAAA,OAAA,CAAA,kHACT,GAAG,qGACL,KAAK;;;AAoB3CA,sBAAA,OAAA,MAAO,UAAQ,CAAlC,SAAS,UAAK;2rBAKqE,QAAK,CAAA,6FAC3C,OAAO;;;AAerCA,sBAAA,OAAA,MAAO,iBAAe,CAArC,KAAK,UAAK;8uBAMmC,GAAG,CAAA,kBAAA;AAAA;;iBAcrD,MAAA,OAAK;AAAE,cAAA,OAAAR,eAAAC,WAAA,EAAA,OAAM,yFAAqF,MAAA,CAAA,CAAA,mUAAA;;UAItG,IAAG;AAAA,UAAI,OAAM;AAAA,QAAA;2BAAvB,CAAwL,GAAAC,QAAAC,UAAA,aAAA;;;;;gCAAtB,aAAW;AAAA,cAAA;AAAA;;;;;;AAGnK,cAAA,OAAAH,eAAAC,WAAA,EAAA,OAAM,mDAA+C,MAAA,CAAA,CAAA,0IAAA;AAAA;;;;;;;;;;;","names":["ChartJS","_ssrRenderAttrs","_mergeProps","_push","_parent","_createVNode","_ssrInterpolate","_ssrRenderAttr","_ssrRenderStyle","_ssrRenderList"],"sources":["../../../../pages/report/[id].vue"],"sourcesContent":["<template>\n  <div class=\"fade-in-up\" v-if=\"report\">\n    <div class=\"flex flex-col md:flex-row md:items-center justify-between mb-margin gap-4\">\n      <NuxtLink to=\"/dashboard\" class=\"flex items-center justify-center gap-2 px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-surface-tint font-label-caps text-[10px] md:text-label-caps hover:bg-surface-tint hover:text-background transition-all shadow-[0_0_15px_rgba(0,219,233,0.1)] hover:shadow-[0_0_30px_rgba(0,219,233,0.3)] min-h-[44px]\">\n        <span class=\"material-symbols-outlined text-sm\">arrow_back</span> Back to Dashboard\n      </NuxtLink>\n      <button @click=\"printReport\" class=\"flex items-center justify-center gap-2 px-4 py-3 rounded-lg bg-surface-tint text-background font-label-caps text-[10px] md:text-label-caps shadow-[0_0_20px_rgba(0,219,233,0.3)] hover:shadow-[0_0_40px_rgba(0,219,233,0.5)] transition-all min-h-[44px]\">\n        <span class=\"material-symbols-outlined text-sm\">print</span> Export PDF\n      </button>\n    </div>\n\n    <!-- Premium Report Header -->\n    <div class=\"glass-panel rounded-2xl mb-margin p-8 md:p-10 overflow-hidden relative border border-outline-variant/20 dark:border-white/10 shadow-[0_20px_50px_rgba(0,0,0,0.1)] dark:shadow-[0_20px_50px_rgba(0,0,0,0.5)]\">\n      <div class=\"absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-surface-tint via-primary to-surface-tint opacity-70\"></div>\n      <div class=\"absolute -top-24 -right-24 w-64 h-64 bg-surface-tint/10 rounded-full blur-[100px] pointer-events-none\"></div>\n      \n      <div class=\"flex flex-col lg:flex-row lg:items-start justify-between gap-8 relative z-10\">\n        <div class=\"space-y-6 flex-1\">\n          <div class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface-tint/10 border border-surface-tint/20 text-surface-tint font-label-caps text-[10px] tracking-[0.2em] shadow-[0_0_15px_rgba(0,219,233,0.1)]\">\n            <span class=\"material-symbols-outlined text-sm animate-pulse\">verified_user</span> \n            SECURE RISK ASSESSMENT\n          </div>\n          \n          <div class=\"space-y-2\">\n            <h1 class=\"font-headline-xl text-4xl md:text-5xl lg:text-6xl text-on-surface text-glow-cyan tracking-tight leading-tight\">\n              {{ report.title }}\n            </h1>\n            <p class=\"text-on-surface-variant font-body-lg text-lg opacity-80 max-w-2xl\">\n              Comprehensive threat analysis and vulnerability assessment generated by Gemini AI Engine.\n            </p>\n          </div>\n\n          <div class=\"flex flex-wrap items-center gap-6 font-data-mono text-xs text-outline pt-4 border-t border-outline-variant/10 dark:border-white/5\">\n            <div class=\"flex items-center gap-2 px-3 py-1 rounded-md bg-surface-variant/30 dark:bg-white/5\">\n              <span class=\"material-symbols-outlined text-sm text-surface-tint\">calendar_today</span>\n              <span class=\"opacity-70\">GENERATED:</span>\n              <span class=\"text-on-surface\">{{ new Date(report.createdAt).toLocaleDateString() }}</span>\n            </div>\n            <div class=\"flex items-center gap-2 px-3 py-1 rounded-md bg-surface-variant/30 dark:bg-white/5\">\n              <span class=\"material-symbols-outlined text-sm text-surface-tint\">database</span>\n              <span class=\"opacity-70\">SOURCE:</span>\n              <span class=\"text-on-surface uppercase\">{{ report.sourceType }}</span>\n            </div>\n            <div class=\"flex items-center gap-2 px-3 py-1 rounded-md bg-surface-variant/30 dark:bg-white/5\">\n              <span class=\"material-symbols-outlined text-sm text-surface-tint\">fingerprint</span>\n              <span class=\"opacity-70\">ID:</span>\n              <span class=\"text-on-surface\">#{{ report._id.substring(0, 8) }}</span>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"flex flex-col items-center justify-center p-8 rounded-2xl bg-surface-variant/20 dark:bg-black/40 border border-outline-variant/20 dark:border-white/5 min-w-[240px] relative group\">\n          <div class=\"absolute inset-0 bg-surface-tint/5 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity\"></div>\n          <div class=\"text-outline font-label-caps text-[10px] tracking-[0.3em] mb-4 uppercase\">Risk Index</div>\n          <div class=\"relative w-32 h-32 flex items-center justify-center\">\n            <svg class=\"w-full h-full transform -rotate-90\">\n              <circle class=\"text-outline-variant/20\" stroke=\"currentColor\" stroke-width=\"8\" fill=\"transparent\" r=\"58\" cx=\"64\" cy=\"64\"/>\n              <circle :class=\"getRiskColorClass(report.overallScore, 'text')\" stroke=\"currentColor\" stroke-width=\"8\" :stroke-dasharray=\"2 * Math.PI * 58\" :stroke-dashoffset=\"2 * Math.PI * 58 * (1 - report.overallScore / 100)\" stroke-linecap=\"round\" fill=\"transparent\" r=\"58\" cx=\"64\" cy=\"64\" class=\"transition-all duration-1000 ease-out\"/>\n            </svg>\n            <div class=\"absolute flex flex-col items-center\">\n              <span class=\"font-display-lg text-4xl md:text-5xl text-on-surface\">{{ report.overallScore }}</span>\n              <span class=\"font-label-caps text-[8px] text-outline tracking-widest\">/ 100</span>\n            </div>\n          </div>\n          <div class=\"mt-4 font-label-caps text-xs tracking-widest\" :class=\"getRiskColorClass(report.overallScore)\">\n            {{ getRiskLevelLabel(report.overallScore) }} CRITICALITY\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Threat Analysis Bento Grid -->\n    <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-gutter mb-margin\">\n      <!-- Risk Vector Visualization -->\n      <div class=\"lg:col-span-7\">\n        <div class=\"glass-panel rounded-2xl p-8 h-full flex flex-col border border-white/10\">\n          <div class=\"flex items-center justify-between mb-8\">\n            <h3 class=\"font-headline-md text-2xl text-on-surface flex items-center gap-3\">\n              <span class=\"p-2 rounded-lg bg-surface-tint/10 text-surface-tint\">\n                <span class=\"material-symbols-outlined block\">radar</span>\n              </span>\n              Risk Vector Analysis\n            </h3>\n            <div class=\"flex items-center gap-2 text-[10px] font-label-caps text-outline bg-surface-variant/30 dark:bg-white/5 px-3 py-1 rounded-full border border-outline-variant/10\">\n              <span class=\"w-2 h-2 rounded-full bg-surface-tint animate-pulse\"></span> LIVE PROFILE\n            </div>\n          </div>\n          <div class=\"flex-1 min-h-[350px] relative flex items-center justify-center\">\n            <Radar v-if=\"chartData\" :data=\"chartData\" :options=\"chartOptions\" />\n          </div>\n        </div>\n      </div>\n\n      <!-- Threat Actor Profile Section -->\n      <div class=\"lg:col-span-5\">\n        <div class=\"glass-panel rounded-2xl p-8 h-full border border-white/10 relative overflow-hidden\">\n          <div class=\"absolute top-0 right-0 p-8 opacity-10 pointer-events-none\">\n            <span class=\"material-symbols-outlined text-[120px]\">security</span>\n          </div>\n          \n          <h3 class=\"font-headline-md text-2xl text-on-surface flex items-center gap-3 mb-8\">\n            <span class=\"p-2 rounded-lg bg-secondary-container/10 text-secondary-container\">\n              <span class=\"material-symbols-outlined block\">person_search</span>\n            </span>\n            Threat Profile\n          </h3>\n\n          <div class=\"space-y-8 relative z-10\">\n            <!-- Confidence Meter -->\n            <div class=\"space-y-4\">\n              <div class=\"flex items-center justify-between\">\n                <span class=\"font-label-caps text-[10px] tracking-widest text-outline uppercase\">AI Certainty Index</span>\n                <span class=\"font-data-mono text-sm text-surface-tint\">{{ report.confidenceScore }}%</span>\n              </div>\n              <div class=\"h-3 w-full bg-surface-variant/30 dark:bg-white/5 rounded-full overflow-hidden p-0.5 border border-outline-variant/20 dark:border-white/5\">\n                <div class=\"h-full bg-gradient-to-r from-surface-tint to-primary rounded-full shadow-[0_0_15px_rgba(0,219,233,0.5)] transition-all duration-1000\" :style=\"{ width: report.confidenceScore + '%' }\"></div>\n              </div>\n            </div>\n\n            <!-- Profile Details -->\n            <div class=\"grid grid-cols-2 gap-4\">\n              <div class=\"p-4 rounded-xl bg-surface-variant/20 dark:bg-white/5 border border-outline-variant/20 dark:border-white/5 space-y-2\">\n                <span class=\"text-[9px] font-label-caps text-outline tracking-wider uppercase\">Intent Level</span>\n                <p class=\"text-on-surface font-medium\">{{ report.overallScore > 70 ? 'Hostile / Targeted' : 'Opportunistic' }}</p>\n              </div>\n              <div class=\"p-4 rounded-xl bg-surface-variant/20 dark:bg-white/5 border border-outline-variant/20 dark:border-white/5 space-y-2\">\n                <span class=\"text-[9px] font-label-caps text-outline tracking-wider uppercase\">Capability</span>\n                <p class=\"text-on-surface font-medium\">{{ report.overallScore > 60 ? 'Advanced / Persistent' : 'Moderate' }}</p>\n              </div>\n            </div>\n\n            <!-- Threat Vectors List -->\n            <div class=\"space-y-4\">\n              <span class=\"text-[10px] font-label-caps text-outline tracking-widest uppercase block border-b border-outline-variant/10 dark:border-white/5 pb-2\">Primary Attack Vectors</span>\n              <div class=\"space-y-3\">\n                <div v-for=\"(score, cat) in report.categoryScores\" :key=\"cat\" v-show=\"score > 50\" class=\"flex items-center justify-between p-3 rounded-lg bg-surface-tint/5 border-l-2 border-surface-tint\">\n                  <span class=\"text-xs font-medium text-on-surface capitalize\">{{ cat }}</span>\n                  <span class=\"text-[10px] font-data-mono text-surface-tint\">{{ score }} PTS</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Findings & Recommendations -->\n    <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-gutter mb-margin\">\n      <!-- Strategic Findings -->\n      <div class=\"glass-panel rounded-2xl p-8 border border-white/10\">\n        <h3 class=\"font-headline-md text-2xl text-on-surface flex items-center gap-3 mb-8\">\n          <span class=\"p-2 rounded-lg bg-surface-tint/10 text-surface-tint\">\n            <span class=\"material-symbols-outlined block\">find_in_page</span>\n          </span>\n          Critical Findings\n         </h3>\n        <div class=\"space-y-4\">\n          <div v-for=\"(finding, index) in report.findings\" :key=\"index\" class=\"group flex gap-5 p-6 rounded-2xl bg-surface-variant/10 dark:bg-white/[0.03] border border-outline-variant/10 dark:border-white/5 hover:border-surface-tint/30 hover:bg-surface-variant/20 dark:hover:bg-white/[0.05] transition-all\">\n            <div class=\"w-10 h-10 rounded-full bg-surface-tint/10 flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform\">\n              <span class=\"material-symbols-outlined text-surface-tint text-xl\">priority_high</span>\n            </div>\n            <div class=\"space-y-1\">\n              <span class=\"text-[9px] font-label-caps text-outline tracking-widest uppercase\">Finding #{{ index + 1 }}</span>\n              <p class=\"text-on-surface-variant leading-relaxed\">{{ finding }}</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Mitigation Roadmap -->\n      <div class=\"glass-panel rounded-2xl p-8 border border-white/10\">\n        <h3 class=\"font-headline-md text-2xl text-on-surface flex items-center gap-3 mb-8\">\n          <span class=\"p-2 rounded-lg bg-secondary-container/10 text-secondary-container\">\n            <span class=\"material-symbols-outlined block\">gavel</span>\n          </span>\n          Remediation Roadmap\n        </h3>\n        <div class=\"space-y-4\">\n          <div v-for=\"(rec, index) in report.recommendations\" :key=\"index\" class=\"group flex gap-5 p-6 rounded-2xl bg-secondary-container/5 border border-outline-variant/10 dark:border-white/5 hover:border-secondary-container/30 hover:bg-secondary-container/10 transition-all\">\n            <div class=\"w-10 h-10 rounded-full bg-secondary-container/10 flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform\">\n              <span class=\"material-symbols-outlined text-secondary-container text-xl\">task_alt</span>\n            </div>\n            <div class=\"space-y-1\">\n              <span class=\"text-[9px] font-label-caps text-outline tracking-widest uppercase\">Action Item</span>\n              <p class=\"text-on-surface-variant leading-relaxed\">{{ rec }}</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"flex items-center justify-center pt-8 border-t border-outline-variant/20 dark:border-white/5\">\n       <button @click=\"printReport\" class=\"flex items-center gap-3 px-8 py-4 rounded-xl bg-surface-tint text-background font-label-caps tracking-widest hover:brightness-110 transition-all shadow-2xl hover:shadow-surface-tint/40\">\n         <span class=\"material-symbols-outlined\">download</span> DOWNLOAD FULL PDF DOSSIER\n       </button>\n    </div>\n  </div>\n\n  <div v-else-if=\"error\" class=\"min-h-[60vh] flex flex-col items-center justify-center text-center space-y-stack-lg\">\n    <span class=\"material-symbols-outlined text-display-lg text-error opacity-50\">error</span>\n    <h2 class=\"font-headline-xl text-on-surface\">Report Not Found</h2>\n    <p class=\"text-outline\">The report you're looking for doesn't exist or has been removed.</p>\n    <NuxtLink to=\"/\" class=\"px-stack-lg py-stack-md bg-surface-tint text-background rounded-lg font-label-caps text-label-caps shadow-[0_0_20px_rgba(0,219,233,0.3)]\">Return Home</NuxtLink>\n  </div>\n  \n  <div v-else class=\"min-h-[60vh] flex items-center justify-center\">\n    <div class=\"animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-surface-tint\"></div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted, computed } from 'vue';\nimport { useRoute, useRouter } from 'vue-router';\nimport {\n  Chart as ChartJS,\n  RadialLinearScale,\n  PointElement,\n  LineElement,\n  Filler,\n  Tooltip,\n  Legend\n} from 'chart.js';\nimport { Radar } from 'vue-chartjs';\n\nChartJS.register(\n  RadialLinearScale,\n  PointElement,\n  LineElement,\n  Filler,\n  Tooltip,\n  Legend\n);\n\nconst route = useRoute();\nconst router = useRouter();\nconst report = ref(null);\nconst error = ref(null);\n\nconst fetchReport = async () => {\n    const config = useRuntimeConfig();\n    try {\n        const response = await fetch(`${config.public.apiBase}/reports/${route.params.id}`, {\n            credentials: 'include'\n        });\n        \n        if (!response.ok) {\n            if (response.status === 404) {\n                throw new Error('Report not found');\n            }\n            throw new Error('Failed to fetch report');\n        }\n        \n        const data = await response.json();\n        // Handle both response formats\n        report.value = data.report || data;\n        error.value = null;\n        \n    } catch (err) {\n        console.error('Error fetching report:', err);\n        error.value = err.message;\n    }\n};\n\nonMounted(fetchReport);\n\nconst getRiskColorClass = (score, type = 'text') => {\n    if (score >= 66) {\n        return type === 'text' ? 'text-secondary-container' : (type === 'border' ? 'border-secondary-container/50' : 'bg-secondary-container');\n    }\n    if (score >= 33) {\n        return type === 'text' ? 'text-yellow-500' : (type === 'border' ? 'border-yellow-500/50' : 'bg-yellow-500');\n    }\n    return type === 'text' ? 'text-surface-tint' : (type === 'border' ? 'border-surface-tint/50' : 'bg-surface-tint');\n};\n\nconst getRiskLevelLabel = (score) => {\n    if (score >= 66) return 'CRITICAL';\n    if (score >= 33) return 'MODERATE';\n    return 'MINIMAL';\n};\n\nconst printReport = () => window.print();\n\nconst chartData = computed(() => {\n    if (!report.value || !report.value.categoryScores) return null;\n    const cats = report.value.categoryScores;\n    return {\n        labels: ['Financial', 'Operational', 'Market', 'Legal', 'Reputational'],\n        datasets: [{\n            label: 'Risk Score',\n            backgroundColor: 'rgba(0, 219, 233, 0.2)',\n            borderColor: 'rgba(0, 219, 233, 1)',\n            pointBackgroundColor: 'rgba(0, 219, 233, 1)',\n            pointBorderColor: '#fff',\n            pointHoverBackgroundColor: '#fff',\n            pointHoverBorderColor: 'rgba(0, 219, 233, 1)',\n            data: [\n                cats.financial || 0, \n                cats.operational || 0, \n                cats.market || 0, \n                cats.legal || 0, \n                cats.reputational || 0\n            ]\n        }]\n    };\n});\n\nconst chartOptions = {\n    responsive: true,\n    maintainAspectRatio: false,\n    scales: {\n        r: {\n            angleLines: { color: 'rgba(255, 255, 255, 0.1)' },\n            grid: { color: 'rgba(255, 255, 255, 0.05)' },\n            pointLabels: { \n              color: '#849495', \n              font: { \n                size: 11, \n                family: 'Space Grotesk',\n                weight: '600'\n              } \n            },\n            ticks: { display: false, min: 0, max: 100 }\n        }\n    },\n    plugins: {\n        legend: { display: false }\n    }\n};\n</script>\n\n<style scoped>\n/* Scoped styles if needed */\n</style>"],"version":3}